<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Neon Breakout</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#0d0f1a;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:'Segoe UI',sans-serif;color:#f0f2ff;}
canvas{border:2px solid rgba(0,229,255,0.3);border-radius:8px;cursor:none;}
.hint{margin-top:10px;font-size:12px;color:#7a82a8;}
</style>
</head>
<body>
<canvas id="c" width="400" height="500"></canvas>
<div class="hint">Move mouse or use ← → keys &nbsp;|&nbsp; Space to launch</div>
<script>
const canvas=document.getElementById('c'),ctx=canvas.getContext('2d');
const W=400,H=500;
const BRICK_ROWS=6,BRICK_COLS=10,BRICK_W=36,BRICK_H=16,BRICK_PAD=2,BRICK_OFF_X=4,BRICK_OFF_Y=50;
const BALL_R=7,PAD_W=70,PAD_H=10,PAD_Y=H-30;
const COLORS=['#ff4fd8','#ff6b35','#ffe033','#00ff99','#00e5ff','#a855f7'];

let ball,pad,bricks,score,lives,state='idle',frame=0;

function init(){
  ball={x:W/2,y:PAD_Y-BALL_R-1,vx:3*(Math.random()>0.5?1:-1),vy:-4,launched:false};
  pad={x:W/2-PAD_W/2};
  bricks=[];score=0;lives=3;
  for(let r=0;r<BRICK_ROWS;r++)for(let c=0;c<BRICK_COLS;c++){
    bricks.push({x:BRICK_OFF_X+c*(BRICK_W+BRICK_PAD),y:BRICK_OFF_Y+r*(BRICK_H+BRICK_PAD),color:COLORS[r],alive:true,pts:(BRICK_ROWS-r)*10});
  }
  state='play';
}

function tick(){
  if(state!=='play')return;
  frame++;
  if(!ball.launched){ball.x=pad.x+PAD_W/2;return;}
  ball.x+=ball.vx;ball.y+=ball.vy;
  // walls
  if(ball.x-BALL_R<0){ball.x=BALL_R;ball.vx*=-1;}
  if(ball.x+BALL_R>W){ball.x=W-BALL_R;ball.vx*=-1;}
  if(ball.y-BALL_R<0){ball.y=BALL_R;ball.vy*=-1;}
  // paddle
  if(ball.vy>0&&ball.y+BALL_R>=PAD_Y&&ball.y+BALL_R<=PAD_Y+PAD_H&&ball.x>pad.x&&ball.x<pad.x+PAD_W){
    ball.vy=Math.abs(ball.vy)*-1;
    ball.vx=((ball.x-(pad.x+PAD_W/2))/(PAD_W/2))*5;
  }
  // bottom
  if(ball.y>H+20){
    lives--;ball.launched=false;ball.x=W/2;ball.y=PAD_Y-BALL_R-1;
    if(lives<=0){state='dead';}
  }
  // bricks
  for(const b of bricks){
    if(!b.alive)continue;
    if(ball.x+BALL_R>b.x&&ball.x-BALL_R<b.x+BRICK_W&&ball.y+BALL_R>b.y&&ball.y-BALL_R<b.y+BRICK_H){
      b.alive=false;score+=b.pts;
      const overlapX=Math.min(ball.x+BALL_R-b.x,b.x+BRICK_W-(ball.x-BALL_R));
      const overlapY=Math.min(ball.y+BALL_R-b.y,b.y+BRICK_H-(ball.y-BALL_R));
      if(overlapX<overlapY)ball.vx*=-1;else ball.vy*=-1;
      break;
    }
  }
  if(bricks.every(b=>!b.alive)){state='win';}
}

function draw(){
  ctx.fillStyle='#070910';ctx.fillRect(0,0,W,H);
  // bricks
  for(const b of bricks){
    if(!b.alive)continue;
    ctx.fillStyle=b.color;
    ctx.beginPath();ctx.roundRect(b.x,b.y,BRICK_W,BRICK_H,3);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.25)';ctx.fillRect(b.x+2,b.y+2,BRICK_W-4,3);
  }
  // ball glow
  ctx.shadowBlur=15;ctx.shadowColor='#00e5ff';
  ctx.fillStyle='#00e5ff';
  ctx.beginPath();ctx.arc(ball.x,ball.y,BALL_R,0,Math.PI*2);ctx.fill();
  ctx.shadowBlur=0;
  // paddle
  const pg=ctx.createLinearGradient(pad.x,0,pad.x+PAD_W,0);
  pg.addColorStop(0,'#00b4d8');pg.addColorStop(1,'#00e5ff');
  ctx.fillStyle=pg;
  ctx.beginPath();ctx.roundRect(pad.x,PAD_Y,PAD_W,PAD_H,5);ctx.fill();
  // HUD
  ctx.fillStyle='rgba(0,0,0,0.4)';ctx.fillRect(0,0,W,44);
  ctx.fillStyle='#00e5ff';ctx.font='bold 16px Segoe UI';ctx.textAlign='left';
  ctx.fillText('Score: '+score,12,28);
  ctx.textAlign='center';ctx.fillStyle='#ff4fd8';
  ctx.fillText('❤ '.repeat(lives).trim(),W/2,28);
  ctx.textAlign='right';ctx.fillStyle='#ffe033';
  ctx.fillText('NEON BREAKOUT',W-12,28);
  // states
  if(state==='idle'){
    ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fillRect(0,180,W,140);
    ctx.fillStyle='#ffe033';ctx.font='bold 28px Segoe UI';ctx.textAlign='center';
    ctx.fillText('NEON BREAKOUT',W/2,230);
    ctx.fillStyle='#aaa';ctx.font='15px Segoe UI';
    ctx.fillText('Move mouse to aim, Space to launch',W/2,265);
    ctx.fillStyle='#00e5ff';ctx.fillText('Click to Start',W/2,295);
  }
  if(state==='dead'){
    ctx.fillStyle='rgba(0,0,0,0.7)';ctx.fillRect(0,180,W,140);
    ctx.fillStyle='#ff4fd8';ctx.font='bold 30px Segoe UI';ctx.textAlign='center';
    ctx.fillText('GAME OVER',W/2,230);
    ctx.fillStyle='#fff';ctx.font='18px Segoe UI';
    ctx.fillText('Score: '+score,W/2,265);
    ctx.fillStyle='#00e5ff';ctx.font='14px Segoe UI';
    ctx.fillText('Click to play again',W/2,295);
  }
  if(state==='win'){
    ctx.fillStyle='rgba(0,0,0,0.7)';ctx.fillRect(0,180,W,140);
    ctx.fillStyle='#ffe033';ctx.font='bold 30px Segoe UI';ctx.textAlign='center';
    ctx.fillText('YOU WIN! 🎉',W/2,230);
    ctx.fillStyle='#fff';ctx.font='18px Segoe UI';
    ctx.fillText('Score: '+score,W/2,265);
    ctx.fillStyle='#00e5ff';ctx.font='14px Segoe UI';
    ctx.fillText('Click to play again',W/2,295);
  }
}

function loop(){tick();draw();requestAnimationFrame(loop);}
loop();

canvas.addEventListener('mousemove',e=>{
  const r=canvas.getBoundingClientRect();
  pad.x=Math.max(0,Math.min(W-PAD_W,(e.clientX-r.left)-PAD_W/2));
});
canvas.addEventListener('click',e=>{
  if(state==='idle'||state==='dead'||state==='win'){init();return;}
  if(!ball.launched)ball.launched=true;
});
document.addEventListener('keydown',e=>{
  if(e.code==='Space'){e.preventDefault();if(state==='play'&&!ball.launched)ball.launched=true;}
  if(e.key==='ArrowLeft')pad.x=Math.max(0,pad.x-20);
  if(e.key==='ArrowRight')pad.x=Math.min(W-PAD_W,pad.x+20);
});
</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Asteroids</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#0d0f1a;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:'Segoe UI',sans-serif;}
canvas{border:2px solid rgba(0,229,255,0.2);border-radius:8px;}
.hint{color:#7a82a8;font-size:12px;margin-top:8px;}
</style>
</head>
<body>
<canvas id="c" width="480" height="480"></canvas>
<div class="hint">WASD or Arrow keys to move &nbsp;|&nbsp; Space to shoot</div>
<script>
const canvas=document.getElementById('c'),ctx=canvas.getContext('2d');
const W=480,H=480,TAU=Math.PI*2;
let ship,bullets,asteroids,score,lives,state,frame,keys={};

function Ship(){
  return{x:W/2,y:H/2,angle:-Math.PI/2,vx:0,vy:0,dead:false,inv:0};
}
function Asteroid(x,y,size){
  const angle=Math.random()*TAU,spd=(3-size)*0.8+0.5;
  const pts=[];const n=7+Math.floor(Math.random()*5);
  for(let i=0;i<n;i++){const a=i/n*TAU,r=size*12+Math.random()*size*6;pts.push({x:Math.cos(a)*r,y:Math.sin(a)*r});}
  return{x,y,vx:Math.cos(angle)*spd,vy:Math.sin(angle)*spd,size,pts,rot:0,rotSpd:(Math.random()-0.5)*0.05};
}

function init(){
  ship=Ship();bullets=[];asteroids=[];score=0;lives=3;frame=0;state='play';
  for(let i=0;i<5;i++){
    let x,y;
    do{x=Math.random()*W;y=Math.random()*H;}while(Math.hypot(x-W/2,y-H/2)<100);
    asteroids.push(Asteroid(x,y,3));
  }
}

function wrap(v,max){return((v%max)+max)%max;}

function tick(){
  if(state!=='play')return;
  frame++;
  const turn=0.04,thrust=0.18,drag=0.99;
  if(keys['ArrowLeft']||keys['a'])ship.angle-=turn;
  if(keys['ArrowRight']||keys['d'])ship.angle+=turn;
  if(keys['ArrowUp']||keys['w']){ship.vx+=Math.cos(ship.angle)*thrust;ship.vy+=Math.sin(ship.angle)*thrust;}
  ship.vx*=drag;ship.vy*=drag;
  ship.x=wrap(ship.x+ship.vx,W);ship.y=wrap(ship.y+ship.vy,H);
  if(ship.inv>0)ship.inv--;
  // bullets
  bullets=bullets.filter(b=>{b.x+=b.vx;b.y+=b.vy;b.life--;return b.life>0&&b.x>-10&&b.x<W+10&&b.y>-10&&b.y<H+10;});
  // asteroids
  for(const a of asteroids){a.x=wrap(a.x+a.vx,W);a.y=wrap(a.y+a.vy,H);a.rot+=a.rotSpd;}
  // bullet-asteroid collisions
  for(let i=bullets.length-1;i>=0;i--){
    for(let j=asteroids.length-1;j>=0;j--){
      const a=asteroids[j],b=bullets[i];
      if(Math.hypot(a.x-b.x,a.y-b.y)<a.size*14){
        bullets.splice(i,1);asteroids.splice(j,1);
        score+=a.size===1?100:a.size===2?50:20;
        if(a.size>1){
          for(let k=0;k<2;k++)asteroids.push(Asteroid(a.x+Math.random()*20-10,a.y+Math.random()*20-10,a.size-1));
        }
        break;
      }
    }
  }
  // ship-asteroid
  if(ship.inv<=0){
    for(const a of asteroids){
      if(Math.hypot(a.x-ship.x,a.y-ship.y)<a.size*12){
        lives--;ship.inv=120;ship.vx=0;ship.vy=0;ship.x=W/2;ship.y=H/2;
        if(lives<=0){state='dead';return;}
        break;
      }
    }
  }
  if(asteroids.length===0){
    // next wave
    for(let i=0;i<5+Math.floor(score/300);i++){
      let x,y;do{x=Math.random()*W;y=Math.random()*H;}while(Math.hypot(x-ship.x,y-ship.y)<120);
      asteroids.push(Asteroid(x,y,3));
    }
  }
}

function draw(){
  ctx.fillStyle='#07090e';ctx.fillRect(0,0,W,H);
  // stars
  ctx.fillStyle='rgba(255,255,255,0.5)';
  for(let i=0;i<60;i++){ctx.fillRect((i*73+11)%W,(i*47+7)%H,1,1);}
  // asteroids
  for(const a of asteroids){
    ctx.save();ctx.translate(a.x,a.y);ctx.rotate(a.rot);
    ctx.strokeStyle='rgba(180,180,220,0.8)';ctx.lineWidth=1.5;
    ctx.beginPath();a.pts.forEach((p,i)=>{if(!i)ctx.moveTo(p.x,p.y);else ctx.lineTo(p.x,p.y);});
    ctx.closePath();ctx.stroke();ctx.restore();
  }
  // bullets
  ctx.shadowBlur=8;ctx.shadowColor='#00e5ff';
  ctx.fillStyle='#00e5ff';
  for(const b of bullets){ctx.beginPath();ctx.arc(b.x,b.y,2.5,0,TAU);ctx.fill();}
  ctx.shadowBlur=0;
  // ship
  if(ship.inv===0||frame%4<2){
    ctx.save();ctx.translate(ship.x,ship.y);ctx.rotate(ship.angle);
    ctx.strokeStyle='#00e5ff';ctx.lineWidth=2;
    ctx.beginPath();ctx.moveTo(16,0);ctx.lineTo(-10,9);ctx.lineTo(-6,0);ctx.lineTo(-10,-9);ctx.closePath();ctx.stroke();
    if(keys['ArrowUp']||keys['w']){
      ctx.strokeStyle='#ff6b35';ctx.beginPath();
      ctx.moveTo(-6,0);ctx.lineTo(-16+(Math.random()*4),0);ctx.stroke();
    }
    ctx.restore();
  }
  // HUD
  ctx.fillStyle='#00e5ff';ctx.font='bold 16px Segoe UI';ctx.textAlign='left';
  ctx.fillText('Score: '+score,12,28);
  ctx.textAlign='right';ctx.fillStyle='#ff4fd8';
  ctx.fillText('❤ '.repeat(lives).trim(),W-12,28);
  if(state==='dead'){
    ctx.fillStyle='rgba(0,0,0,0.65)';ctx.fillRect(0,170,W,140);
    ctx.fillStyle='#ff4fd8';ctx.font='bold 32px Segoe UI';ctx.textAlign='center';
    ctx.fillText('GAME OVER',W/2,225);
    ctx.fillStyle='#fff';ctx.font='18px Segoe UI';ctx.fillText('Score: '+score,W/2,258);
    ctx.fillStyle='#00e5ff';ctx.font='14px Segoe UI';ctx.fillText('Press Space to play again',W/2,285);
  }
  if(state==='idle'){
    ctx.fillStyle='rgba(0,0,0,0.65)';ctx.fillRect(0,170,W,140);
    ctx.fillStyle='#ffe033';ctx.font='bold 30px Segoe UI';ctx.textAlign='center';
    ctx.fillText('ASTEROIDS',W/2,220);
    ctx.fillStyle='#aaa';ctx.font='15px Segoe UI';
    ctx.fillText('WASD to move, Space to shoot',W/2,255);
    ctx.fillStyle='#00e5ff';ctx.fillText('Press Space to start',W/2,285);
  }
}

function loop(){tick();draw();requestAnimationFrame(loop);}
state='idle';loop();

let shootCool=0;
document.addEventListener('keydown',e=>{
  keys[e.key]=true;
  if(e.code==='Space'){
    e.preventDefault();
    if(state!=='play'){init();return;}
    if(shootCool<=0){
      bullets.push({x:ship.x+Math.cos(ship.angle)*18,y:ship.y+Math.sin(ship.angle)*18,vx:Math.cos(ship.angle)*9+ship.vx,vy:Math.sin(ship.angle)*9+ship.vy,life:55});
      shootCool=12;
    }
  }
});
document.addEventListener('keyup',e=>{keys[e.key]=false;});
setInterval(()=>{if(shootCool>0)shootCool--;},16);
</script>
</body>
</html>
